[
    "# Non-rules get passed through",
    [ true, {}, true ],
    [ false, {}, false ],
    [ 17, {}, 17 ],
    [ 3.14, {}, 3.14 ],
    [ "apple", {}, "apple" ],
    [ null, {}, null ],
    [ ["a","b"], {}, ["a","b"] ],

    "# Single operator tests",
    [ {"===":[1,1]}, {}, true ],
    [ {"===":[1,2]}, {}, false ],
    [ {"!==":[1,2]}, {}, true ],
    [ {"!==":[1,1]}, {}, false ],
    [ {">":[2,1]}, {}, true ],
    [ {">":[1,1]}, {}, false ],
    [ {">":[1,2]}, {}, false ],
    [ {">=":[2,1]}, {}, true ],
    [ {">=":[1,1]}, {}, true ],
    [ {">=":[1,2]}, {}, false ],
    [ {"<":[2,1]}, {}, false ],
    [ {"<":[1,1]}, {}, false ],
    [ {"<":[1,2]}, {}, true ],
    [ {"<=":[2,1]}, {}, false ],
    [ {"<=":[1,1]}, {}, true ],
    [ {"<=":[1,2]}, {}, true ],
    [ {"or":[true,true]}, {}, true ],
    [ {"or":[false,true]}, {}, true ],
    [ {"or":[true,false]}, {}, true ],
    [ {"or":[false,false]}, {}, false ],
    [ {"or":[false,false,true]}, {}, true ],
    [ {"or":[false,false,false]}, {}, false ],
    [ {"or":[false]}, {}, false ],
    [ {"or":[true]}, {}, true ],
    [ {"and":[true,true]}, {}, true ],
    [ {"and":[false,true]}, {}, false ],
    [ {"and":[true,false]}, {}, false ],
    [ {"and":[false,false]}, {}, false ],
    [ {"and":[true,true,true]}, {}, true ],
    [ {"and":[true,true,false]}, {}, false ],
    [ {"and":[false]}, {}, false ],
    [ {"and":[true]}, {}, true ],
    [ {"in":["Bart",["Bart","Homer","Lisa","Marge","Maggie"]]}, {}, true ],
    [ {"in":["Milhouse",["Bart","Homer","Lisa","Marge","Maggie"]]}, {}, false ],
    [ {"in":["Spring","Springfield"]}, {}, true ],
    [ {"in":["i","team"]}, {}, false ],

    "# Compound Tests",
    [ {"and":[{">":[3,1]},true]}, {}, true ],
    [ {"and":[{">":[3,1]},false]}, {}, false ],
    [ {"and":[{">":[3,1]},{"<":[1,3]}]}, {}, true ],

    "# Data-Driven",
    [ {"var":["a"]},{"a":1},1 ],
    [ {"var":["b"]},{"a":1},null ],
    [ {"var":["a"]},null,null ],
    [ {"var":"a"},{"a":1},1 ],
    [ {"var":"b"},{"a":1},null ],
    [ {"var":"a"},null,null ],

    [ {"in":[{"var":"filling"},["apple","cherry"]]},{"filling":"apple"},true ],
    [ {"var":""}, 1, 1 ],
    [ {"var":null}, 1, 1 ],
    [ {"var":[]}, 1, 1 ],
]
